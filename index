<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Review Verification Bureau</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500;700&family=Source+Serif+4:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #14203A;
    --ink-soft: #2A3A5C;
    --folder: #D8BE8A;
    --folder-dark: #C2A268;
    --paper: #F4EFE1;
    --rule: #B79F6E;
    --text: #221D14;
    --text-soft: #6B5F47;
    --genuine: #2F6F4F;
    --mixed: #B2793A;
    --fake: #A83A32;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--folder);
    background-image:
      radial-gradient(circle at 15% 10%, rgba(0,0,0,0.04) 0, transparent 40%),
      radial-gradient(circle at 85% 90%, rgba(0,0,0,0.04) 0, transparent 40%);
    color: var(--text);
    font-family: 'Source Serif 4', Georgia, serif;
    min-height: 100vh;
  }

  header.masthead {
    background: var(--ink);
    color: #EDE6D3;
    padding: 28px 24px 22px;
    text-align: center;
    border-bottom: 6px solid var(--folder-dark);
  }

  header.masthead h1 {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: clamp(24px, 4vw, 34px);
    letter-spacing: 0.5px;
    margin: 0 0 6px;
  }

  header.masthead p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #B7C4DE;
    margin: 0;
  }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 36px 20px 80px;
  }

  .intake-card {
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 28px;
    box-shadow: 0 8px 24px rgba(20, 32, 58, 0.18);
    position: relative;
  }

  .intake-card::before {
    content: "INTAKE FORM";
    position: absolute;
    top: -11px;
    left: 24px;
    background: var(--folder);
    padding: 2px 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text-soft);
  }

  .intake-card label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-soft);
    margin-bottom: 8px;
  }

  .input-row {
    display: flex;
    gap: 10px;
  }

  .input-row input {
    flex: 1;
    padding: 12px 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: #fff;
    color: var(--text);
  }

  .input-row input:focus {
    outline: 2px solid var(--ink);
    outline-offset: 1px;
  }

  button.submit-btn {
    padding: 12px 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    background: var(--ink);
    color: #EDE6D3;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  button.submit-btn:hover { background: var(--ink-soft); }
  button.submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .hint {
    margin-top: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-soft);
  }

  .hint a.demo-link {
    color: var(--ink);
    font-weight: 700;
    text-decoration: underline;
    cursor: pointer;
  }

  #status {
    margin-top: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--text-soft);
    display: none;
  }

  #status.visible { display: block; }

  .spinner {
    display: inline-block;
    width: 10px; height: 10px;
    border: 2px solid var(--rule);
    border-top-color: var(--ink);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-right: 8px;
    vertical-align: middle;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  #error-box {
    margin-top: 18px;
    padding: 14px 16px;
    background: #F6E4E1;
    border-left: 4px solid var(--fake);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #6B2A24;
    display: none;
  }

  .report-card {
    margin-top: 28px;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 32px 28px 28px;
    position: relative;
    box-shadow: 0 10px 30px rgba(20, 32, 58, 0.22);
    display: none;
  }

  .report-card.visible {
    display: block;
    animation: slideIn 0.35s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .stamp {
    position: absolute;
    top: 18px;
    right: 24px;
    width: 108px;
    height: 108px;
    border-radius: 50%;
    border: 3px double currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transform: rotate(-9deg);
    line-height: 1.25;
    padding: 10px;
    animation: stamp-in 0.4s cubic-bezier(.36,1.4,.4,1);
  }

  @keyframes stamp-in {
    0% { transform: rotate(-9deg) scale(1.8); opacity: 0; }
    100% { transform: rotate(-9deg) scale(1); opacity: 1; }
  }

  .stamp.genuine { color: var(--genuine); }
  .stamp.mixed { color: var(--mixed); }
  .stamp.fake { color: var(--fake); }

  .score-block {
    max-width: 60%;
  }

  .score-block .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .score-block .score {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 56px;
    line-height: 1;
    margin: 4px 0 6px;
  }

  .score-block .verdict {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 500;
  }

  .disclaimer {
    margin-top: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    line-height: 1.6;
    color: var(--text-soft);
    font-style: italic;
    border-top: 1px dashed var(--rule);
    padding-top: 12px;
  }

  .exhibit-log-title {
    margin-top: 26px;
    margin-bottom: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-soft);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 8px;
  }

  .exhibit {
    padding: 16px 0;
    border-bottom: 1px solid var(--rule);
  }

  .exhibit:last-child { border-bottom: none; }

  .exhibit-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  .exhibit-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-soft);
    letter-spacing: 1px;
  }

  .exhibit-name {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 16px;
  }

  .exhibit-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
  }

  .exhibit-quote {
    margin: 8px 0 10px;
    font-style: italic;
    font-size: 14px;
    color: var(--text);
    line-height: 1.5;
  }

  .bar-track {
    height: 6px;
    background: #E3D9BE;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .bar-fill {
    height: 100%;
    border-radius: 3px;
  }

  .flags {
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .flag-chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 10px;
    background: #F6E4E1;
    color: #6B2A24;
    border: 1px solid #D9B5AF;
  }

  footer {
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink);
    opacity: 0.55;
    padding: 20px;
  }
</style>
</head>
<body>

<header class="masthead">
  <h1>Review Verification Bureau</h1>
  <p>Automated review authenticity assessment</p>
</header>

<main>
  <div class="intake-card">
    <label for="url-input">Product URL (Amazon.in)</label>
    <div class="input-row">
      <input type="text" id="url-input" placeholder="https://www.amazon.in/dp/..." />
      <button class="submit-btn" id="submit-btn">Open Case File</button>
    </div>
    <p class="hint">Paste a full Amazon.in product page link. Analysis covers the 5 most recent reviews.</p>
    <p class="hint" style="margin-top:6px;">Demo build — try one of these real, pre-analyzed products:<br>
      <a href="#" class="demo-link" data-url="https://www.amazon.in/dp/B0GYCT961V/">Sandalwood Saffron Face Wash</a> &middot;
      <a href="#" class="demo-link" data-url="https://www.amazon.in/dp/B09S6M7JQJ/">Sandalwood Saffron Soap</a>
    </p>

    <div id="status">
      <span class="spinner"></span><span id="status-text">Reviewing case...</span>
    </div>
    <div id="error-box"></div>
  </div>

  <div class="report-card" id="report-card">
    <div class="stamp" id="stamp"></div>
    <div class="score-block">
      <div class="label">Trust Score</div>
      <div class="score" id="score-value">--</div>
      <div class="verdict" id="verdict-text"></div>
    </div>
    <p class="disclaimer">
      This is an automated estimate based on review text and behavioral patterns.
      It is not a definitive judgment of product or seller authenticity, and should
      not be the sole basis for a purchasing decision.
    </p>

    <div class="exhibit-log-title">Exhibit Log &mdash; Reviews Examined</div>
    <div id="exhibit-list"></div>
  </div>
</main>

<footer>Local prototype &middot; for demonstration purposes</footer>

<script>
const submitBtn = document.getElementById('submit-btn');
const urlInput = document.getElementById('url-input');
const statusBox = document.getElementById('status');
const statusText = document.getElementById('status-text');
const errorBox = document.getElementById('error-box');
const reportCard = document.getElementById('report-card');
const stamp = document.getElementById('stamp');
const scoreValue = document.getElementById('score-value');
const verdictText = document.getElementById('verdict-text');
const exhibitList = document.getElementById('exhibit-list');

function verdictClass(label) {
  if (label.includes('Genuine')) return 'genuine';
  if (label.includes('Mixed')) return 'mixed';
  return 'fake';
}

function verdictStampWord(label) {
  if (label.includes('Genuine')) return 'GENUINE';
  if (label.includes('Mixed')) return 'MIXED\nSIGNALS';
  return 'SUSPECT';
}

function barColor(score) {
  if (score >= 0.7) return 'var(--genuine)';
  if (score >= 0.4) return 'var(--mixed)';
  return 'var(--fake)';
}

async function runCheck() {
  const url = urlInput.value.trim();
  if (!url) {
    errorBox.textContent = 'Please paste a product URL first.';
    errorBox.style.display = 'block';
    return;
  }

  errorBox.style.display = 'none';
  reportCard.classList.remove('visible');
  submitBtn.disabled = true;
  statusBox.classList.add('visible');
  statusText.textContent = 'Scraping recent reviews...';

  try {
    const stageTimer = setTimeout(() => {
      statusText.textContent = 'Running authenticity analysis (first run downloads a model, may take a minute)...';
    }, 2500);

    const res = await fetch('/api/check', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url })
    });
    clearTimeout(stageTimer);
    const data = await res.json();

    if (data.error) {
      errorBox.textContent = data.error;
      errorBox.style.display = 'block';
      return;
    }

    renderReport(data);
  } catch (err) {
    errorBox.textContent = 'Something went wrong reaching the server: ' + err.message;
    errorBox.style.display = 'block';
  } finally {
    submitBtn.disabled = false;
    statusBox.classList.remove('visible');
  }
}

function renderReport(data) {
  const vClass = verdictClass(data.label);
  stamp.className = 'stamp ' + vClass;
  stamp.style.whiteSpace = 'pre-line';
  stamp.textContent = verdictStampWord(data.label);

  scoreValue.textContent = data.trust_score + '/100';
  scoreValue.style.color = 'var(--' + vClass + ')';
  verdictText.textContent = data.label + ' \u2014 based on ' + data.reviews_analyzed + ' recent reviews';

  exhibitList.innerHTML = '';
  data.per_review.forEach((r, i) => {
    const letter = String.fromCharCode(65 + i);
    const div = document.createElement('div');
    div.className = 'exhibit';

    let flagsHtml = '';
    if (r.ai_leftover_detected) {
      flagsHtml += '<span class="flag-chip">AI text leftover detected</span>';
    }
    if (r.uniqueness_score < 0.3) {
      flagsHtml += '<span class="flag-chip">Duplicate content</span>';
    }

    div.innerHTML = `
      <div class="exhibit-header">
        <span class="exhibit-tag">EXHIBIT ${letter}</span>
        <span class="exhibit-score" style="color:${barColor(r.review_score)}">${r.review_score.toFixed(2)}</span>
      </div>
      <div class="exhibit-name">${r.reviewer_name || 'Unknown reviewer'}</div>
      <div class="exhibit-quote">&ldquo;${r.review_text_preview}&hellip;&rdquo;</div>
      <div class="bar-track"><div class="bar-fill" style="width:${r.review_score*100}%; background:${barColor(r.review_score)}"></div></div>
      ${flagsHtml ? `<div class="flags">${flagsHtml}</div>` : ''}
    `;
    exhibitList.appendChild(div);
  });

  reportCard.classList.add('visible');
}

submitBtn.addEventListener('click', runCheck);
urlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runCheck(); });

document.querySelectorAll('.demo-link').forEach(link => {
  link.addEventListener('click', (e) => {
    e.preventDefault();
    urlInput.value = link.dataset.url;
    runCheck();
  });
});
</script>

</body>
</html>
